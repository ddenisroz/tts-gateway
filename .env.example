# tts-gateway minimal env example
# Most scheduling, timeout, and circuit-breaker knobs already have sane defaults in app/config.py.

TTS_GATEWAY_HOST=0.0.0.0
TTS_GATEWAY_PORT=8010
TTS_GATEWAY_PUBLIC_BASE_URL=http://localhost:8010
TTS_GATEWAY_API_KEYS=change-me
TTS_GATEWAY_REDIS_URL=redis://localhost:6379/0

TTS_GATEWAY_F5_URL=http://localhost:8011
TTS_GATEWAY_F5_API_KEY=
TTS_GATEWAY_QWEN_URL=http://localhost:8012
TTS_GATEWAY_QWEN_API_KEY=
